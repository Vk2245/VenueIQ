# =============================================================================
# VenueIQ Environment Configuration
# Copy this file to .env and fill in your values
# ALL services below are FREE — no GCP billing required!
# =============================================================================

# --- Google Gemini AI ---
# Get your API key from: https://aistudio.google.com/apikey (FREE)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Service Account ---
# Generate from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# This is completely FREE on the Spark plan (no billing needed)
GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-credentials.json

# --- Google Sheets API (FREE, no billing) ---
# 1. Create a new Google Sheet
# 2. Share it with the service account email from your credentials JSON
# 3. Copy the Sheet ID from the URL (the long string between /d/ and /edit)
GOOGLE_SHEETS_ID=your_google_sheet_id_here

# --- Firebase (Spark Plan — FREE, no billing) ---
# Firebase project configuration (from Firebase Console > Project Settings)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Google reCAPTCHA v3 (FREE) ---
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# --- Application Settings ---
# Secret key for token generation (generate with: python -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=your_secret_key_here_change_in_production
# Environment: development | production
APP_ENV=development
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
# Server port
PORT=8000

# --- Demo Mode ---
# Enable demo mode for evaluators (set to true for hackathon submission)
DEMO_MODE=true
